// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Billing composition: PlanCard + PlanComparisonTable > free plan renders upgrade options 1`] = `"<div><div class="rounded-lg border border-border bg-surface-card p-lg"><div class="flex items-center gap-sm mb-md"><span class="text-lg font-semibold">Free</span></div></div><div class="overflow-x-auto"><table class="w-full text-sm"><thead><tr><th class="text-left p-sm"></th><th class="text-center p-sm font-semibold">Free</th><th class="text-center p-sm font-semibold">Pro</th><th class="text-center p-sm font-semibold">Team</th></tr></thead><tbody><tr class="border-t border-border"><td class="p-sm font-medium">Rules</td><td class="text-center p-sm">10</td><td class="text-center p-sm">100</td><td class="text-center p-sm">Unlimited</td></tr><tr class="border-t border-border"><td class="p-sm font-medium">Collections</td><td class="text-center p-sm">3</td><td class="text-center p-sm">20</td><td class="text-center p-sm">∞</td></tr><tr class="border-t border-border"><td class="p-sm font-medium">Cloud Sync</td><td class="text-center p-sm">No</td><td class="text-center p-sm">Yes</td><td class="text-center p-sm">Yes</td></tr><tr class="border-t border-border"><td class="p-sm"></td><td class="text-center p-sm"><span class="text-xs text-content-secondary font-medium">Current Plan</span></td><td class="text-center p-sm"><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-primary text-white hover:bg-primary-hover px-sm py-xs text-sm  ">Upgrade</button></td><td class="text-center p-sm"><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-primary text-white hover:bg-primary-hover px-sm py-xs text-sm  ">Upgrade</button></td></tr></tbody></table></div></div>"`;

exports[`Logging composition: LogPanel + LogEntryList + LogToolbar > LogEntryList renders entries with mocked/real icons 1`] = `"<div class="flex-1 overflow-y-auto"><div class="flex flex-col"><div class="flex items-center gap-xs px-sm py-xs border-b border-border text-xs font-mono cursor-pointer hover:bg-surface-secondary transition-colors"><span class="inline-flex items-center px-sm py-xs text-xs font-semibold rounded bg-surface-secondary text-content-secondary " style="background-color: rgba(16, 185, 129, 0.125); color: rgb(16, 185, 129);">GET</span><span class="flex-1 truncate text-content-primary">https://api.example.com/users</span><img src="/src/ui/icons/shield.svg" alt="" width="16" height="16" class="shrink-0"><span class="text-green-500">200</span><span class="text-content-muted">50ms</span></div><div class="flex items-center gap-xs px-sm py-xs border-b border-border text-xs font-mono cursor-pointer hover:bg-surface-secondary transition-colors"><span class="inline-flex items-center px-sm py-xs text-xs font-semibold rounded bg-surface-secondary text-content-secondary " style="background-color: rgba(59, 130, 246, 0.125); color: rgb(59, 130, 246);">POST</span><span class="flex-1 truncate text-content-primary">https://api.example.com/posts</span><img src="/src/ui/icons/globe.svg" alt="" width="16" height="16" class="shrink-0"><span class="text-red-700">500</span><span class="text-content-muted">200ms</span></div></div></div>"`;

exports[`Logging composition: LogPanel + LogEntryList + LogToolbar > LogPanel renders toolbar and entry list when open 1`] = `"<div class="flex flex-col max-h-[40vh] border-t border-border bg-surface-primary"><div class="flex items-center justify-between px-sm py-xs border-b border-border"><span class="text-sm font-semibold text-content-primary">Logs</span><div class="flex items-center gap-xs"><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed text-content-secondary hover:text-content-primary hover:bg-surface-secondary px-sm py-xs text-sm  " aria-label="Pause"><img src="/src/ui/icons/pause.svg" alt="" width="16" height="16"></button><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed text-content-secondary hover:text-content-primary hover:bg-surface-secondary px-sm py-xs text-sm  " aria-label="Clear"><img src="/src/ui/icons/trash.svg" alt="" width="16" height="16"></button><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed text-content-secondary hover:text-content-primary hover:bg-surface-secondary px-sm py-xs text-sm  " aria-label="Close"><img src="/src/ui/icons/close.svg" alt="" width="16" height="16"></button></div></div><div class="flex-1 overflow-y-auto"><div class="flex flex-col"><div class="flex items-center gap-xs px-sm py-xs border-b border-border text-xs font-mono cursor-pointer hover:bg-surface-secondary transition-colors"><span class="inline-flex items-center px-sm py-xs text-xs font-semibold rounded bg-surface-secondary text-content-secondary " style="background-color: rgba(16, 185, 129, 0.125); color: rgb(16, 185, 129);">GET</span><span class="flex-1 truncate text-content-primary">https://api.example.com/users</span><img src="/src/ui/icons/shield.svg" alt="" width="16" height="16" class="shrink-0"><span class="text-green-500">200</span><span class="text-content-muted">50ms</span></div><div class="flex items-center gap-xs px-sm py-xs border-b border-border text-xs font-mono cursor-pointer hover:bg-surface-secondary transition-colors"><span class="inline-flex items-center px-sm py-xs text-xs font-semibold rounded bg-surface-secondary text-content-secondary " style="background-color: rgba(59, 130, 246, 0.125); color: rgb(59, 130, 246);">POST</span><span class="flex-1 truncate text-content-primary">https://api.example.com/posts</span><img src="/src/ui/icons/globe.svg" alt="" width="16" height="16" class="shrink-0"><span class="text-red-700">500</span><span class="text-content-muted">200ms</span></div></div></div></div>"`;

exports[`Recording composition: RecordButton + RecordPopover > RecordPopover shows empty state when no tabs 1`] = `"<div class="flex flex-col gap-sm p-md rounded-lg bg-surface-card border border-border"><h3 class="text-sm font-medium text-content-primary">Record API Responses</h3><p class="text-sm text-content-secondary">No tabs available</p><div class="flex items-center gap-sm justify-end"><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed text-content-secondary hover:text-content-primary hover:bg-surface-secondary px-sm py-xs text-sm  ">Cancel</button><button class="inline-flex items-center justify-center rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-primary text-white hover:bg-primary-hover px-sm py-xs text-sm  " disabled="">Start Recording</button></div></div>"`;

